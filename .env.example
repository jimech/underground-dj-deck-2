# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional comma-separated extra frontend origins allowed to call the API.
# Use this for preview URLs in addition to APP_URL. Do not use "*" for public apps.
CORS_ALLOWED_ORIGINS="https://preview.example.com,https://staging.example.com"

# VITE_API_BASE_URL: Public browser-visible API origin for local/full-stack frontend calls.
# This is not a secret. Do not put API keys in VITE_* variables.
VITE_API_BASE_URL="http://localhost:8787"

# Supabase browser auth config. These are public client values, not service-role secrets.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY"

# SESSION_STORAGE_DRIVER: Backend storage selector. Use "memory" for local development
# or "supabase" after applying the Supabase migration and setting server-only credentials.
SESSION_STORAGE_DRIVER="memory"

# Supabase server-only credentials. Never expose the service role key in VITE_* vars
# or frontend code. Add real values only in local .env or deployment secrets.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
